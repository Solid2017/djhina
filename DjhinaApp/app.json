{
  "expo": {
    "name": "Djhina",
    "slug": "djhina-rijasi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.djhina.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Djhina a besoin de la caméra pour scanner les QR codes d'accès aux événements.",
        "NSPhotoLibraryUsageDescription": "Djhina a besoin d'accéder à la galerie pour les photos de profil.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A1E"
      },
      "package": "com.djhina.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Djhina a besoin de la caméra pour scanner les QR codes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Djhina accède à votre galerie pour changer votre photo de profil.",
          "cameraPermission": "Djhina accède à votre caméra pour prendre une photo de profil."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0b4f3d03-275a-4bed-8ff3-6e26fff8e686"
      }
    },
    "owner": "igotech"
  }
}
