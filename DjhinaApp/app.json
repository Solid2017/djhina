{
  "expo": {
    "name": "Djhina",
    "slug": "djhina-rijasi",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.djhina.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Djhina utilise la caméra pour scanner les QR codes d'accès aux événements.",
        "NSPhotoLibraryUsageDescription": "Djhina accède à votre galerie pour changer votre photo de profil.",
        "NSPhotoLibraryAddUsageDescription": "Djhina peut sauvegarder votre QR code dans la galerie.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A1E"
      },
      "package": "com.djhina.app",
      "versionCode": 2,
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24,
      "allowBackup": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Djhina utilise la caméra pour scanner les QR codes d'accès aux événements."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Djhina accède à votre galerie pour changer votre photo de profil.",
          "cameraPermission": "Djhina accède à votre caméra pour prendre une photo de profil."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "0b4f3d03-275a-4bed-8ff3-6e26fff8e686"
      }
    },
    "owner": "igotech",
    "updates": {
      "url": "https://u.expo.dev/0b4f3d03-275a-4bed-8ff3-6e26fff8e686"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
