{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Djhina Backend (dev)",
      "cwd": "DjhinaBackend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Djhina Backend (prod)",
      "cwd": "DjhinaBackend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 3000
