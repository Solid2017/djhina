    {
      "name": "Djhina App (web)",
      "cwd": "DjhinaApp",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web"],
      "port": 8081
    },
    {
      "name": "Djhina App (Expo DevTools)",
      "cwd": "DjhinaApp",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 19000
    },
    {
      "name": "Djhina App (Android)",
      "cwd": "DjhinaApp",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 19000
    }
  ]
}
